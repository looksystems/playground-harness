[
  {
    "name": "echo_simple",
    "command": "echo hello world",
    "expected_stdout": "hello world\n",
    "expected_stderr": "",
    "expected_exit_code": 0
  },
  {
    "name": "pwd_default",
    "command": "pwd",
    "expected_stdout": "/\n",
    "expected_stderr": "",
    "expected_exit_code": 0
  },
  {
    "name": "cat_hello_file",
