{
  "name": "noodlehq/agent-harness-php",
  "autoload": {
    "psr-4": {
      "AgentHarness\\": "src/php",
      "AgentHarness\\Generated\\": "src/php/Generated"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AgentHarness\\Tests\\": "tests/php"
    }
  },
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.0",
    "grpc/grpc": "^1.60",
    "google/protobuf": "^4.25"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  }
}
